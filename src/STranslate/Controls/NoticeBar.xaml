<UserControl
    x:Class="STranslate.Controls.NoticeBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:plugin="clr-namespace:STranslate.Plugin;assembly=STranslate.Plugin"
    x:Name="Root"
    Background="{x:Null}"
    Focusable="False">
    <UserControl.Resources>
        <Style x:Key="NoticeIconStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="24" />
            <Setter Property="Margin" Value="0,1,10,0" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Text" Value="ⓘ" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Success}">
                    <Setter Property="Text" Value="✓" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Warning}">
                    <Setter Property="Text" Value="⚠" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Error}">
                    <Setter Property="Text" Value="✕" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoticeTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoticeActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="12,0,0,0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="Content" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Content" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoticeCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Content" Value="×" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="ToolTip" Value="{DynamicResource Close}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsClosable, ElementName=Root}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border
        Padding="12,10"
        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Style="{StaticResource NoticeIconStyle}" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource NoticeTitleStyle}" Text="{Binding Title, ElementName=Root}" />
                <TextBlock
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding Message, ElementName=Root}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Button
                Grid.Column="2"
                Click="OnActionButtonClick"
                Content="{Binding ActionText, ElementName=Root}"
                Style="{StaticResource NoticeActionButtonStyle}" />

            <Button
                Grid.Column="3"
                AutomationProperties.Name="{DynamicResource Close}"
                Click="OnCloseButtonClick"
                Style="{StaticResource NoticeCloseButtonStyle}" />
        </Grid>
    </Border>
</UserControl>
